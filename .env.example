# Copy to .env and edit. All variables are optional — with none set, the demo
# runs on the deterministic offline mock provider.

# Provider: auto | vertex | anthropic | mock   (default: auto)
A2A_MCP_PROVIDER=auto

# Model id (Claude on Vertex AI or Anthropic API)
A2A_MCP_MODEL=claude-sonnet-4-6
A2A_MCP_MAX_TOKENS=1024

# --- Claude on Vertex AI (primary) ---
# Authenticate first: gcloud auth application-default login
A2A_MCP_VERTEX_PROJECT_ID=
A2A_MCP_VERTEX_REGION=us-east5

# --- Direct Anthropic API (fallback) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Local A2A loopback endpoints ---
A2A_MCP_HOST=127.0.0.1
A2A_MCP_RESEARCHER_PORT=8801
A2A_MCP_ANALYST_PORT=8802
